# Postgres DB
POSTGRES_USER=xxxclub_scraper
POSTGRES_PASSWORD=xxxclub_scraper
POSTGRES_DB=xxxclub
POSTGRES_PORT=5432
POSTGRES_HOST_PORT=5432

# Redis cache
REDIS_URL=redis://redis:6379

# Scraper settings
BASE_URL=https://xxxclub.to
SCRAPE_INTERVAL=3600 # 1 hour
MAX_PAGES=10

# ThePornDB metadata enrichment
PORNDB_API_KEY=your_api_key_here
METADATA_INTERVAL=300 # seconds between metadata fetch cycles
METADATA_MIN_SCORE=0.65 # minimum match score (0.0–1.0); lower = more matches, higher = fewer false positives

# Components — enable each independently
WATCHER=true       # page watcher + metadata fetcher
API_SERVER=true    # REST API server (JSON)
WEB_UI=true        # HTML web UI (requires API_SERVER or a remote API_URL)
STREMIO=true       # Stremio addon routes mounted on the web UI at /stremio/

# Stremio addon — debrid integration via StremThru
# STREMTHRU_URL=https://stremthru.13377001.xyz  # default public instance; set to your own if self-hosting

# Web UI / API settings
WEB_PORT=5000
API_PORT=5001
# API_URL=http://localhost:5001  # override if API runs on a different host
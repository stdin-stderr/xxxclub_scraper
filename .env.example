# Postgres DB
POSTGRES_USER=xxxclub_scraper
POSTGRES_PASSWORD=xxxclub_scraper
POSTGRES_DB=xxxclub
POSTGRES_PORT=5432
POSTGRES_HOST_PORT=5432

# Scraper settings
BASE_URL=https://xxxclub.to
SCRAPE_INTERVAL=3600 # 1 hour
MAX_PAGES=10

# ThePornDB metadata enrichment
PORNDB_API_KEY=your_api_key_here
METADATA_INTERVAL=300 # seconds between metadata fetch cycles
METADATA_MIN_SCORE=0.6 # minimum match score (0.0–1.0); lower = more matches, higher = fewer false positives

# Web UI settings
WEB_UI=false
WEB_PORT=5000